# Mirror H5 环境变量配置
# 复制此文件为 .env.local 并填写真实值

# OpenAI API（用于 Whisper 转写 + GPT 分析）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Supabase Storage（存储录音文件）
VITE_STORAGE_BUCKET=audio

# API 基础 URL（开发环境留空，生产环境填写真实域名）
VITE_API_URL=

# Vercel 部署时的域名（用于分享链接生成）
# 在 Vercel 项目 Settings → Domains 中获取
VERCEL_URL=https://mirror.app

# 分享功能：静态页面渲染用的域名
NEXT_PUBLIC_SITE_URL=https://mirror.app
